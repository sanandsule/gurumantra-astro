---
import "../styles/global.css";
import Header from "../components/astro/Header.astro";
import Footer from "../components/astro/Footer.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Gurumantra - AI Career Accelerator</title>
		<meta name="description" content="Build AI skills, projects, and careers with Gurumantra." />
	</head>
	<body class="bg-black text-white selection:bg-purple-500 selection:text-white">
		<Header />
		<slot />
		<Footer />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
